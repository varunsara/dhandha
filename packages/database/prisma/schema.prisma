// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String
  phone       String?   @unique
  password    String
  role        UserRole  @default(CONSUMER)
  isVerified  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  profile     UserProfile?
  properties  Property[]
  agentProperties Property[] @relation("AgentProperties")
  sessions    Session[]
  accounts    Account[]

  @@map("users")
}

model UserProfile {
  id               String             @id @default(cuid())
  userId           String             @unique
  avatar           String?
  bio              String?
  street           String?
  city             String?
  state            String?
  pinCode          String?
  country          String             @default("India")
  latitude         Float?
  longitude        Float?
  language         String             @default("en")
  currency         String             @default("INR")
  emailNotifications Boolean          @default(true)
  smsNotifications Boolean            @default(true)
  pushNotifications Boolean           @default(true)
  identityVerified Boolean            @default(false)
  phoneVerified    Boolean            @default(false)
  emailVerified    Boolean            @default(false)
  professionalVerified Boolean?
  documentsVerified Boolean?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Property {
  id                   String                @id @default(cuid())
  title                String
  description          String
  type                 PropertyType
  category             PropertyCategory
  price                Int
  area                 Float
  areaUnit             AreaUnit
  street               String
  area_name            String
  city                 String
  state                String
  pinCode              String
  country              String                @default("India")
  latitude             Float
  longitude            Float
  nearbyLandmarks      String[]
  amenities            String[]
  images               String[]
  status               PropertyStatus        @default(DRAFT)
  isVerified           Boolean               @default(false)
  verifiedBy           String?
  verifiedAt           DateTime?
  legalStatus          LegalStatus           @default(UNKNOWN)
  titleVerification    Boolean               @default(false)
  documentVerification Boolean               @default(false)
  locationVerification Boolean               @default(false)
  priceVerification    Boolean               @default(false)
  ownerId              String
  agentId              String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  owner                User                  @relation(fields: [ownerId], references: [id])
  agent                User?                 @relation("AgentProperties", fields: [agentId], references: [id])
  documents            PropertyDocument[]
  inquiries            PropertyInquiry[]

  @@map("properties")
}

model PropertyDocument {
  id           String       @id @default(cuid())
  propertyId   String
  name         String
  type         DocumentType
  url          String
  isVerified   Boolean      @default(false)
  uploadedAt   DateTime     @default(now())

  property     Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_documents")
}

model PropertyInquiry {
  id           String              @id @default(cuid())
  propertyId   String
  userId       String
  message      String
  status       InquiryStatus       @default(PENDING)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  property     Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id])

  @@map("property_inquiries")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum UserRole {
  CONSUMER
  AGENT
  ADMIN
}

enum PropertyType {
  LAND
  PLOT
  VILLA
  APARTMENT
  COMMERCIAL
}

enum PropertyCategory {
  RESIDENTIAL
  COMMERCIAL
  AGRICULTURAL
  INDUSTRIAL
}

enum AreaUnit {
  SQ_FT
  SQ_M
  ACRE
  BIGHA
  GUNTHA
}

enum PropertyStatus {
  DRAFT
  PUBLISHED
  SOLD
  SUSPENDED
}

enum DocumentType {
  TITLE_DEED
  SALE_DEED
  SURVEY_SETTLEMENT
  ENCUMBRANCE_CERTIFICATE
  APPROVED_PLAN
  TAX_RECEIPT
  NOC
}

enum LegalStatus {
  CLEAR
  DISPUTED
  PENDING
  UNKNOWN
}

enum InquiryStatus {
  PENDING
  RESPONDED
  CLOSED
}
# Database
DATABASE_URL="postgresql://username:password@localhost:5432/dhandha"
DB_MAX_CONNECTIONS=20
DB_TIMEOUT=30000

# Authentication
NEXTAUTH_SECRET="your-super-secret-key-for-nextauth"
NEXTAUTH_URL="http://localhost:3000"
JWT_SECRET="your-jwt-secret-key"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_SECRET="your-refresh-token-secret"
REFRESH_TOKEN_EXPIRES_IN="30d"

# OAuth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# OTP Configuration
OTP_EXPIRES_IN=300  # 5 minutes
OTP_LENGTH=6

# API Configuration
NODE_ENV="development"
PORT=3000
API_PORT=3001
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# Rate Limiting
RATE_LIMIT_WINDOW=900000  # 15 minutes
RATE_LIMIT_MAX=100

# File Upload
MAX_FILE_SIZE=10485760  # 10MB
LOCAL_UPLOAD_PATH="./uploads"

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# SMS Provider (Twilio)
SMS_PROVIDER="twilio"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Email Provider (SMTP)
EMAIL_PROVIDER="smtp"
SMTP_HOST="localhost"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""

# Cloud Storage (AWS S3)
STORAGE_PROVIDER="local"  # or "aws"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-south-1"
AWS_S3_BUCKET=""

# Google Maps
GOOGLE_MAPS_API_KEY=""

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Additional Environment Variables for Production
# SSL_CERT_PATH=""
# SSL_KEY_PATH=""
# REDIS_URL=""
# ELASTICSEARCH_URL=""
# SENTRY_DSN=""